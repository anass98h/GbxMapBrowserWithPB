<Window x:Class="GbxMapBrowser.NumberInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Number"
        Width="340"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
        ContentRendered="Window_ContentRendered">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="promptTextBlock"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"
                   FontSize="15"/>

        <TextBox x:Name="numberTextBox"
                 Grid.Row="1"
                 Height="34"
                 Margin="0 14 0 16"
                 Padding="8 0"
                 VerticalContentAlignment="Center"
                 FontSize="15"
                 Background="White"
                 Foreground="Black"
                 BorderBrush="{DynamicResource MahApps.Brushes.AccentBase}"
                 BorderThickness="1"
                 KeyDown="NumberTextBox_KeyDown"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Width="90"
                    Height="30"
                    Margin="5 0"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2"
                    Content="OK"
                    Width="90"
                    Height="30"
                    Margin="5 0 0 0"
                    Background="{DynamicResource MahApps.Brushes.AccentBase}"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="OkButton_Click"/>
        </Grid>
    </Grid>
</Window>
