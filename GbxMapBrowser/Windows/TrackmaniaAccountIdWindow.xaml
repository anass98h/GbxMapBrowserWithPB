<Window x:Class="GbxMapBrowser.Windows.TrackmaniaAccountIdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trackmania Online Setup"
        Height="720"
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22">

            <TextBlock Text="Trackmania Online Setup"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="This setup only saves your Account ID and dedicated server credentials. It does not detect records yet."
                       Margin="0 8 0 22"
                       TextWrapping="Wrap"
                       Foreground="Gray"/>

            <!-- Step 1 -->
            <TextBlock Text="Step 1: Trackmania Account ID"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="Enter your Trackmania/Nadeo Account ID manually, or detect it automatically from Openplanet logs."
                       Margin="0 6 0 8"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBox x:Name="accountIdTextBox"
                     Height="32"
                     FontSize="14"
                     VerticalContentAlignment="Center"/>

            <TextBlock x:Name="openplanetHelpTextBlock"
                       Margin="0 8 0 0"
                       TextWrapping="Wrap"
                       Foreground="Gray"/>

            <TextBlock x:Name="openplanetDownloadTextBlock"
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="Gray">
                <Run Text="Openplanet download page: "/>
                <Hyperlink NavigateUri="https://openplanet.dev/download"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    https://openplanet.dev/download
                </Hyperlink>
            </TextBlock>

            <StackPanel Orientation="Horizontal"
                        Margin="0 12 0 0">
                <Button x:Name="findAutomaticallyButton"
                        Content="Find my Account ID automatically"
                        Width="230"
                        Height="34"
                        Click="FindAutomaticallyButton_Click"/>

                <Button x:Name="saveAccountIdButton"
                        Content="Save Account ID"
                        Width="130"
                        Height="34"
                        Margin="12 0 0 0"
                        Click="SaveAccountIdButton_Click"/>
            </StackPanel>

            <Separator Margin="0 24 0 18"/>

            <!-- Step 2 -->
            <TextBlock Text="Step 2: Dedicated server credentials"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Margin="0 6 0 8"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}">
                <Run Text="To detect online records later, this app needs a Trackmania dedicated server login and password. "/>
                <Run Text="Do not enter your Ubisoft password here. "/>
                <Run Text="Create a separate dedicated server account and paste that dedicated server login and password below."/>
            </TextBlock>

            <TextBlock Text="How to create the dedicated server account:"
                       Margin="0 10 0 4"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}">
                <Run Text="1. Open this Trackmania server account page: "/>
                <Hyperlink NavigateUri="https://www.trackmania.com/player/dedicated-servers"
                           RequestNavigate="Hyperlink_RequestNavigate">
                    https://www.trackmania.com/player/dedicated-servers
                </Hyperlink>
            </TextBlock>

            <TextBlock Text="2. Sign in with your Ubisoft/Trackmania account in the browser."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="3. On the “MY SERVER ACCOUNTS” page, type a name for your server in the Server Login field."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="4. Click Submit."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="5. The page will generate a password in red text next to the server name you entered."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="6. Copy the server name you typed and paste it into Dedicated server login below."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="7. Copy the generated red password and paste it into Dedicated server password below."
                       Margin="0 4 0 0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock Text="Important: Do not paste your Ubisoft password here. Only paste the generated dedicated server password."
                       Margin="0 8 0 12"
                       TextWrapping="Wrap"
                       FontWeight="SemiBold"
                       Foreground="Orange"/>
            <TextBlock Text="Dedicated server login / server name"
                       Margin="0 6 0 4"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
            <TextBox x:Name="dedicatedServerLoginTextBox"
                     Height="32"
                     FontSize="14"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Generated dedicated server password"
                       Margin="0 12 0 4"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>
            <PasswordBox x:Name="dedicatedServerPasswordBox"
                         Height="32"
                         FontSize="14"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0 18 0 0">
                <Button x:Name="saveDedicatedServerCredentialsButton"
                        Content="Save dedicated server credentials"
                        Width="240"
                        Height="34"
                        Click="SaveDedicatedServerCredentialsButton_Click"/>

                <Button x:Name="deleteDedicatedServerCredentialsButton"
                        Content="Delete saved credentials"
                        Width="180"
                        Height="34"
                        Margin="12 0 0 0"
                        Click="DeleteDedicatedServerCredentialsButton_Click"/>

                <Button Content="Close"
                        Width="90"
                        Height="34"
                        Margin="12 0 0 0"
                        Click="CloseButton_Click"/>
            </StackPanel>

            <TextBlock x:Name="statusTextBlock"
                       Text=""
                       TextWrapping="Wrap"
                       Foreground="Gray"
                       Margin="0 14 0 0"/>

        </StackPanel>
    </ScrollViewer>
</Window>