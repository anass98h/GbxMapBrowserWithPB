<Window x:Class="GbxMapBrowser.MapNavigationHotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Hotkeys"
        Width="430"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Map navigation hotkeys launch the next or previous map from the current map list while the app is running in the background."
                   TextWrapping="Wrap"
                   FontSize="15"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"/>

        <CheckBox x:Name="enabledCheckBox"
                  Grid.Row="1"
                  Content="Enable map navigation hotkeys"
                  Margin="0 16 0 8"
                  FontSize="15"
                  Foreground="{DynamicResource MahApps.Brushes.Text}"/>

        <Grid Grid.Row="2" Margin="0 8 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Forward"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock x:Name="forwardHotkeyTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <Button Grid.Column="2"
                    Content="Set"
                    Height="30"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="SetForwardButton_Click"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Backward"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <TextBlock x:Name="backwardHotkeyTextBlock"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MahApps.Brushes.Text}"/>

            <Button Grid.Column="2"
                    Content="Set"
                    Height="30"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="SetBackwardButton_Click"/>
        </Grid>

        <TextBlock x:Name="captureStatusTextBlock"
                   Grid.Row="4"
                   Margin="0 16 0 0"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource MahApps.Brushes.Text}"/>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Width="90"
                    Height="30"
                    Margin="5 0"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2"
                    Content="Save"
                    Width="90"
                    Height="30"
                    Margin="5 0 0 0"
                    Background="{DynamicResource MahApps.Brushes.AccentBase}"
                    Style="{StaticResource StandardButtonStyle}"
                    Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</Window>
